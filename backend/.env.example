PORT=8787
REPORTS_FILE=data/reports.jsonl
INGESTED_INBOX_FILE=data/ingested-inbox.json
INGEST_API_KEY=
DEVICE_TOKEN_STORE_FILE=data/device-tokens.json
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_RISK_THRESHOLD=35

# LLM runtime:
# - auto: Gateway when LLM_MODEL uses provider/model and Gateway auth exists,
#         otherwise Anthropic direct when ANTHROPIC_API_KEY exists.
# - anthropic: direct Claude through Vercel AI SDK provider.
# - gateway: Vercel AI Gateway string models, e.g. anthropic/claude-sonnet-4.6.
# - off: force heuristic fallback.
LLM_PROVIDER=auto
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_MS=20000
LLM_MAX_OUTPUT_TOKENS=1600
LLM_OUTPUT_MODE=structured
# Rol usado por el agente evaluador final. Cambia este valor para probar otro modelo
# via AI SDK/Gateway sin tocar la orquestacion, los contratos ni los sub-agentes.
MODEL_FRAUD_ANALYZER=claude-sonnet-4-6
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_GATEWAY_API_KEY=

URLHAUS_AUTH_KEY=
PHISHTANK_API_KEY=
PHISHTANK_USER_AGENT=phishtank/nettoxic
CMF_ALERTS_URL=https://www.cmfchile.cl/portal/principal/613/w3-article-49185.html
CMF_CACHE_TTL_MS=21600000

# Gmail real ingest:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/gmail/oauth2/callback
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/nettoxic-gmail
GMAIL_PUBSUB_VERIFICATION_TOKEN=
GMAIL_TOKEN_STORE_FILE=data/gmail-accounts.json
